@model IEnumerable<eProject3.Models.LiquidFillingMachine>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/Dashboard_Layout.cshtml";

}

<h1>Liquid Filling Machines</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ModelName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AirPressure)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AirVolume)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FillingSpeedPerMinute)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FillingRangeML)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.ModelName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.AirPressure)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.AirVolume)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.FillingSpeedPerMinute)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.FillingRangeML)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
