@{
    ViewData["Title"] = "Products";
    Layout = "~/Views/Shared/Dashboard_Layout.cshtml";
}

    <div class="page-content">

        <div class="page-header">
            <div>
                <div class="page-hd-title">Products</div>
                <div class="page-hd-sub">Select product category to manage.</div>
            </div>
        </div>

        <div class="row g-4">

            <!-- Capsule Card -->
            <div class="col-md-4">
                <a asp-controller="CapsuleMachine" asp-action="Index" style="text-decoration:none;">
                    <div class="card product-card shadow-sm">

                        <img src="~/images/capsule-machine.jpg" class="card-img-top">

                        <div class="card-body text-center">
                            <h5 class="card-title">
                                <i class="bi bi-capsule"></i> Capsule Machines
                            </h5>

                            <p class="card-text">
                                Manage capsule filling machines and equipment.
                            </p>

                            <button class="btn btn-primary w-100">
                                Manage Capsules
                            </button>

                        </div>
                    </div>
                </a>
            </div>


            <!-- Tablet Card -->
            <div class="col-md-4">
                <a asp-controller="TabletMachine" asp-action="Index" style="text-decoration:none;">
                    <div class="card product-card shadow-sm">

                        <img src="~/images/tablet-machine.jpg" class="card-img-top">

                        <div class="card-body text-center">

                            <h5 class="card-title">
                                <i class="bi bi-tablet"></i> Tablet Machines
                            </h5>

                            <p class="card-text">
                                Manage tablet production and compression machines.
                            </p>

                            <button class="btn btn-primary w-100">
                                Manage Tablets
                            </button>

                        </div>
                    </div>
                </a>
            </div>


            <!-- Liquid Filling Card -->
            <div class="col-md-4">
                <a asp-controller="LiquidFillingMachine" asp-action="Index" style="text-decoration:none;">
                    <div class="card product-card shadow-sm">

                        <img src="~/images/liquid-machine.jpg" class="card-img-top">

                        <div class="card-body text-center">

                            <h5 class="card-title">
                                <i class="bi bi-droplet-fill"></i> Liquid Filling
                            </h5>

                            <p class="card-text">
                                Manage liquid filling production machines.
                            </p>

                            <button class="btn btn-primary w-100">
                                Manage Liquids
                            </button>

                        </div>
                    </div>
                </a>
            </div>

        </div>

    </div>
</main>