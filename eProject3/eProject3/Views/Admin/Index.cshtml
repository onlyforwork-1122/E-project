@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/Dashboard_Layout.cshtml";
}
    <div class="page-content">

        <div class="page-header">
            <div>
                <div class="breadcrumb-custom"><i class="bi bi-house-fill"></i><i class="bi bi-chevron-right"></i><span>Dashboard</span></div>
                <div class="page-hd-title">Overview</div>
                <div class="page-hd-sub">Here's what's happening at XYZ Pharmaceuticals today.</div>
            </div>
            <button class="btn-primary-custom" onclick="showToast('Report generated!','bi-file-earmark-pdf')">
                <i class="bi bi-download"></i> Export Report
            </button>
        </div>

        <!-- STAT CARDS -->
        <div class="row g-3 mb-4">
            <div class="col-sm-6 col-xl-3">
                <div class="stat-card">
                    <div class="stat-icon" style="background:var(--primary-pale);color:var(--primary);"><i class="bi bi-box-seam-fill"></i></div>
                    <div class="stat-info">
                        <h3 id="stat-products">@ViewBag.Products</h3><p>Total Products</p>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="stat-card">
                    <div class="stat-icon" style="background:var(--purple-light);color:var(--purple);"><i class="bi bi-people-fill"></i></div>
                    <div class="stat-info">
                    <h3 id="stat-careers">@ViewBag.Career</h3><p>Career Applicants</p>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="stat-card">
                    <div class="stat-icon" style="background:var(--accent-light);color:var(--accent);"><i class="bi bi-chat-quote-fill"></i></div>
                    <div class="stat-info">
                    <h3 id="stat-quotes">@ViewBag.Quotes</h3><p>Quotes / Feedback</p>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="stat-card">
                    <div class="stat-icon" style="background:var(--success-light);color:var(--success);"><i class="bi bi-envelope-fill"></i></div>
                    <div class="stat-info">
                    <h3 id="stat-messages">@ViewBag.Contact</h3><p>Contact Messages</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- LOWER ROW -->
        <div class="row g-3">
            <div class="col-lg-7">
                <div class="panel">
                    <div class="panel-header">
                        <div class="panel-title"><i class="bi bi-clock-history"></i> Recent Activity</div>
                        <span style="font-size:12px;color:var(--text-muted);">Last 7 days</span>
                    </div>
                    <div class="panel-body" id="activity-list"></div>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="panel">
                    <div class="panel-header"><div class="panel-title"><i class="bi bi-pie-chart-fill"></i> Product Categories</div></div>
                    <div class="panel-body" id="cat-summary"></div>
                </div>
                <div class="panel mt-3">
                    <div class="panel-header"><div class="panel-title"><i class="bi bi-lightning-charge-fill"></i> Quick Actions</div></div>
                    <div class="panel-body" style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
                        <a href="products.html" class="btn-primary-custom" style="justify-content:center;font-size:12px;padding:9px 10px;text-decoration:none;"><i class="bi bi-plus-circle"></i> Add Product</a>
                        <a href="careers.html" class="btn-primary-custom" style="justify-content:center;font-size:12px;padding:9px 10px;background:var(--accent);text-decoration:none;"><i class="bi bi-people"></i> Applicants</a>
                        <a href="quotes.html" class="btn-primary-custom" style="justify-content:center;font-size:12px;padding:9px 10px;background:var(--purple);text-decoration:none;"><i class="bi bi-chat-quote"></i> Feedback</a>
                        <a href="messages.html" class="btn-primary-custom" style="justify-content:center;font-size:12px;padding:9px 10px;background:var(--success);text-decoration:none;"><i class="bi bi-envelope"></i> Messages</a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</main>