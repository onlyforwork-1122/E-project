@model IEnumerable<eProject3.Models.Candidate>
@{
    ViewData["Title"] = "Careers";
    Layout = "~/Views/Shared/Dashboard_Layout.cshtml";
}

<!-- ═══ MAIN ═══ -->

    <div class="page-content">

        <div class="page-header">
            <div>
                <div class="breadcrumb-custom"><i class="bi bi-house-fill"></i><i class="bi bi-chevron-right"></i><a href="index.html" style="color:inherit;text-decoration:none;">Dashboard</a><i class="bi bi-chevron-right"></i><span>Career Applicants</span></div>
                <div class="page-hd-title">Manage Applicants</div>
                <div class="page-hd-sub">Review, contact, and manage all career applications.</div>
            </div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
                <button class="btn-primary-custom" style="background:var(--success);" onclick="exportAll()"><i class="bi bi-download"></i> Export CSV</button>
            </div>
        </div>

        <!-- STATUS FILTER TABS -->
        <div class="cat-tabs">
            <button class="cat-tab active" onclick="filterStatus('all',this)">All <span id="cnt-all" style="opacity:.6;"></span></button>
            <button class="cat-tab" onclick="filterStatus('pending',this)">⏳ Pending <span id="cnt-pending" style="opacity:.6;"></span></button>
            <button class="cat-tab" onclick="filterStatus('interview',this)">📅 Interview <span id="cnt-interview" style="opacity:.6;"></span></button>
            <button class="cat-tab" onclick="filterStatus('rejected',this)">✗ Rejected <span id="cnt-rejected" style="opacity:.6;"></span></button>
        </div>

        <div class="panel">
            <div class="panel-body p-0">
                <div class="table-wrap">
                    <table class="tbl">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Applicant</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Education</th>
                                <th>Institution</th>
                                <th>Grade/GPA</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="careers-tbody">
                            @foreach(var applicant in Model )
                            {
                                <tr>
                                    <td>@applicant.Id</td>
                                    <td>@applicant.FirstName @applicant.LastName</td>
                                    <td>@applicant.Email</td>
                                    <td>@applicant.Phone</td>
                                    <td>@(applicant.Educations.FirstOrDefault()?.Degree ?? "-")</td>
                                    <td>@(applicant.Educations.FirstOrDefault()?.Institution ?? "-")</td>
                                    <td>@(applicant.Educations.FirstOrDefault()?.Grade ?? "-")</td>
                                    <td><a class="btn-sm-icon btn-view" href="mailto:@applicant.Email" title="email"><i class="bi bi-envelope"></i></a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</main>

<!-- ═══ MODAL: VIEW APPLICANT ═══ -->
<div class="modal-overlay" id="modal-applicant">
    <div class="modal-box modal-lg">
        <div class="modal-head">
            <div class="modal-title">Applicant Details</div>
            <button class="modal-close" onclick="closeModal('modal-applicant')"><i class="bi bi-x"></i></button>
        </div>
        <div class="modal-body" id="applicant-detail-body"></div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('modal-applicant')">Close</button>
        </div>
    </div>
</div>

<!-- ═══ MODAL: EMAIL ═══ -->
<div class="modal-overlay" id="modal-email">
    <div class="modal-box">
        <div class="modal-head">
            <div class="modal-title"><i class="bi bi-envelope-fill" style="color:var(--primary);margin-right:8px;"></i>Send Interview Email</div>
            <button class="modal-close" onclick="closeModal('modal-email')"><i class="bi bi-x"></i></button>
        </div>
        <div class="modal-body">
            <div class="mb-3"><label class="form-label-custom">To</label><input type="email" class="form-control-custom" id="email-to"></div>
            <div class="mb-3"><label class="form-label-custom">Subject</label><input type="text" class="form-control-custom" id="email-subject"></div>
            <div class="mb-3"><label class="form-label-custom">Message</label><textarea class="form-control-custom" id="email-body" rows="7" style="resize:vertical;"></textarea></div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('modal-email')">Cancel</button>
            <button class="btn-primary-custom" onclick="sendEmail()"><i class="bi bi-send-fill"></i> Send Email</button>
        </div>
    </div>
</div>

<!-- ═══ MODAL: CONFIRM DELETE ═══ -->
<div class="modal-overlay" id="modal-confirm">
    <div class="modal-box" style="max-width:400px;">
        <div class="modal-head">
            <div class="modal-title" style="color:var(--danger);"><i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Delete</div>
            <button class="modal-close" onclick="closeModal('modal-confirm')"><i class="bi bi-x"></i></button>
        </div>
        <div class="modal-body"><p style="font-size:14px;color:var(--text-muted);" id="confirm-text"></p></div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('modal-confirm')">Cancel</button>
            <button class="btn-primary-custom" style="background:var(--danger);" id="confirm-ok-btn"><i class="bi bi-trash-fill"></i> Delete</button>
        </div>
    </div>
</div>




