<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/Dashboard/assets/css/shared.css">
    <link rel="stylesheet" href="~/Dashboard/assets/css/messages.css">
    <link rel="stylesheet" href="~/Dashboard/assets/css/career.css">
</head>
<body>
    <div id="sidebar-overlay" onclick="closeSidebar()"></div>

    <!-- ═══ SIDEBAR ═══ -->
    <nav id="sidebar">
        <a class="sidebar-logo" asp-controller="Dashboard" asp-action="Index">
            <div class="logo-icon"><i class="bi bi-capsule"></i></div>
            <div class="logo-text">XYZ Pharma<span>Admin Panel</span></div>
        </a>
        <div class="sidebar-nav">
            <div class="nav-section-title">Main Menu</div>
            <div class="nav-item"><a class="nav-link active" asp-controller="Admin" asp-action="Index"><i class="bi bi-grid-1x2-fill"></i> Dashboard</a></div>
            <div class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Products"><i class="bi bi-box-seam-fill"></i> Products <span class="badge-count" id="nav-products-count">0</span></a></div>
            <div class="nav-section-title">HR &amp; Customers</div>
            <div class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Careers"><i class="bi bi-people-fill"></i> Career Applicants <span class="badge-count" id="nav-careers-count">0</span></a></div>
            <div class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="QuoteUs"><i class="bi bi-chat-quote-fill"></i> Quotes / Feedback <span class="badge-count" id="nav-quotes-count">0</span></a></div>
            <div class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Messages"><i class="bi bi-envelope-fill"></i> Contact Messages <span class="badge-count" id="nav-messages-count">0</span></a></div>
            <div class="nav-section-title">Settings</div>
            <div class="nav-item"><a class="nav-link" href="#" onclick="showToast('Logging out…','bi-box-arrow-right')"><i class="bi bi-box-arrow-right"></i> Logout</a></div>
        </div>
        <div class="sidebar-footer">
            <div class="sidebar-user">
                <div class="user-avatar">SA</div>
                <div class="user-info"><div class="user-name">Super Admin</div><div class="user-role">Administrator</div></div>
                <i class="bi bi-three-dots-vertical" style="color:var(--sidebar-text);cursor:pointer;"></i>
            </div>
        </div>
    </nav>

    <!-- ═══ TOPBAR ═══ -->
    <header id="topbar">
        <button class="icon-btn me-3 d-md-none" onclick="toggleSidebar()"><i class="bi bi-list" style="font-size:20px;"></i></button>
        <div>
            <div class="topbar-title">Dashboard</div>
            <div class="topbar-subtitle">Welcome back, Super Admin</div>
        </div>
        <div class="topbar-search d-none d-lg-block">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Search across dashboard…" oninput="if(this.value)showToast('Searching for &quot;'+this.value+'&quot;','bi-search')">
        </div>
        <div class="topbar-actions">
            <div style="position:relative;">
                <button class="icon-btn" onclick="toggleNotif()" title="Notifications"><i class="bi bi-bell-fill"></i><span class="dot"></span></button>
                <div class="notif-dropdown" id="notif-dropdown">
                    <div style="padding:12px 16px;border-bottom:1px solid var(--border);font-weight:700;font-size:14px;">Notifications</div>
                    <div class="notif-item"><div class="notif-icon" style="background:var(--primary-pale);color:var(--primary);"><i class="bi bi-person-plus-fill"></i></div><div class="notif-text"><p>New application from <strong>James Wilson</strong></p><span>2 minutes ago</span></div></div>
                    <div class="notif-item"><div class="notif-icon" style="background:var(--accent-light);color:var(--accent);"><i class="bi bi-chat-dots-fill"></i></div><div class="notif-text"><p>New quote from <strong>MedCorp Ltd.</strong></p><span>18 minutes ago</span></div></div>
                    <div class="notif-item"><div class="notif-icon" style="background:var(--success-light);color:var(--success);"><i class="bi bi-envelope-fill"></i></div><div class="notif-text"><p>New contact message received</p><span>1 hour ago</span></div></div>
                    <div style="padding:10px 16px;text-align:center;font-size:12.5px;color:var(--primary);font-weight:600;cursor:pointer;border-top:1px solid var(--border);">View all notifications</div>
                </div>
            </div>
            <button class="icon-btn" title="Settings"><i class="bi bi-gear-fill"></i></button>
            <div class="admin-profile-btn" onclick="showToast('Profile settings','bi-person-circle')">
                <div class="user-avatar" style="width:30px;height:30px;font-size:12px;">SA</div>
                <span>Admin</span>
                <i class="bi bi-chevron-down" style="font-size:11px;color:var(--text-muted);"></i>
            </div>
        </div>
    </header>

            <main id="main">
           @RenderBody()
           </main>
       
        <!-- TOAST -->
        <div id="toast"><i class="bi bi-check-circle-fill"></i><span id="toast-msg"></span></div>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
        <script src="~/Dashboard/assets/js/career.js"></script>
        <script src="~/Dashboard/assets/js/messages.js"></script>
        <script src="~/Dashboard/assets/js/products.js"></script>
        <script src="~/Dashboard/assets/js/quotes.js"></script>
        <script src="~/Dashboard/assets/js/shared.js"></script>
        <script>
            function renderStats() {
              document.getElementById('stat-products').textContent  = products.length;
              document.getElementById('stat-careers').textContent   = careers.length;
              document.getElementById('stat-quotes').textContent    = quotes.length;
              document.getElementById('stat-messages').textContent  = messages.length;
              document.getElementById('unread-count').textContent   = messages.filter(m=>m.unread).length;
              updateNavBadges();
            }

            function renderActivity() {
              const items = [
                { icon:'bi-box-seam-fill',    bg:'var(--primary-pale)',  clr:'var(--primary)', text:'Product <strong>AutoCap 500</strong> added to catalog', time:'5 minutes ago' },
                { icon:'bi-person-plus-fill', bg:'var(--purple-light)',  clr:'var(--purple)',  text:'New applicant <strong>James Wilson</strong> applied for Researcher', time:'22 minutes ago' },
                { icon:'bi-chat-quote-fill',  bg:'var(--accent-light)',  clr:'var(--accent)',  text:'Quote request from <strong>MedCorp Ltd.</strong> received', time:'1 hour ago' },
                { icon:'bi-envelope-fill',    bg:'var(--success-light)', clr:'var(--success)', text:'Contact message from <strong>Lisa Chen</strong> via website', time:'3 hours ago' },
                { icon:'bi-trash-fill',       bg:'var(--danger-light)',  clr:'var(--danger)',  text:'Product <strong>OldFill-V1</strong> removed from catalog', time:'Yesterday' },
              ];
              document.getElementById('activity-list').innerHTML = items.map(a => `
                <div class="activity-item">
                  <div class="activity-dot" style="background:${a.bg};color:${a.clr};"><i class="bi ${a.icon}"></i></div>
                  <div class="activity-info"><p>${a.text}</p><span>${a.time}</span></div>
                </div>`).join('');
            }

            function renderCatSummary() {
              const caps = products.filter(p=>p.category==='capsule').length;
              const tabs = products.filter(p=>p.category==='tablet').length;
              const liq  = products.filter(p=>p.category==='liquid').length;
              const tot  = products.length || 1;
              document.getElementById('cat-summary').innerHTML = [
                ['bi-capsule',     'var(--primary)', 'Capsule',       caps, caps/tot],
                ['bi-tablet',      'var(--purple)',  'Tablet',        tabs, tabs/tot],
                ['bi-droplet-fill','var(--accent)',  'Liquid Filling',liq,  liq/tot],
              ].map(([ic,clr,lbl,cnt,pct]) => `
                <div style="margin-bottom:16px;">
                  <div style="display:flex;justify-content:space-between;margin-bottom:5px;">
                    <span style="font-size:13px;font-weight:600;"><i class="bi ${ic} me-2" style="color:${clr};"></i>${lbl}</span>
                    <span style="font-size:13px;font-weight:700;">${cnt}</span>
                  </div>
                  <div class="progress-thin"><div class="bar" style="width:${(pct*100).toFixed(0)}%;background:${clr};"></div></div>
                </div>`).join('');
            }

            renderStats();
            renderActivity();
            renderCatSummary();
        </script>
</body>
</html>
