@model IEnumerable<eProject3.Models.CapsuleMachine>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/Dashboard_Layout.cshtml";

}

<h1>Capsule Machines</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.OutputPerHour)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CapsuleSizeMM)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MachineDimension)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ShippingWeightKG)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.OutputPerHour)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CapsuleSizeMM)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MachineDimension)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ShippingWeightKG)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
