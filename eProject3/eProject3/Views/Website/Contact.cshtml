@model eProject3.Models.Contact

@{
    ViewData["Title"] = "Contact";
    Layout = "~/Views/Shared/_Layout.cshtml";

}




    <div class="toast" id="toast"></div>
@if (ViewBag.Success != null)
{
    <div class="alert alert-success" style="margin-top:1rem;">
        @ViewBag.Success
    </div>
}
    <div class="page active" id="page-contact">
        <div class="page-header">
            <div class="page-header-bg"></div>
            <div class="page-header-content">
                <div class="section-tag">Get In Touch</div>
                <h1>Contact Us</h1>
                <p>We'd love to hear from you. Reach out anytime.</p>
            </div>
        </div>
        <section class="section">
            <div class="grid-2" style="gap:4rem;align-items:start;">
                <div>
                    <h3 style="font-family:var(--font-display);font-size:1.6rem;margin-bottom:1.5rem;">Our Contact Information</h3>

                    <div class="contact-info-card">
                        <div class="contact-icon">📍</div>
                        <div>
                            <div class="contact-info-label">Registered Office</div>
                            <div class="contact-info-value">42 Pharma Industrial Estate,<br />Malir District, Karachi — 000000<br />Karachi, Pakistan</div>
                        </div>
                    </div>
                    <div class="contact-info-card">
                        <div class="contact-icon">📞</div>
                        <div>
                            <div class="contact-info-label">Phone</div>
                            <div class="contact-info-value">+92 22 40125678<br /><span style="font-size:0.85rem;color:var(--text-muted);">Mon–Sat 9:00 AM – 6:00 PM PST</span></div>
                        </div>
                    </div>
                    <div class="contact-info-card">
                        <div class="contact-icon">✉</div>
                        <div>
                            <div class="contact-info-label">Email</div>
                            <div class="contact-info-value"><a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="80e9eee6efc0f8f9faf0e8e1f2ede1aee3efed">[email&#160;protected]</a><br /><span style="font-size:0.85rem;color:var(--text-muted);"><a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="6c1f0d00091f2c1415161c040d1e010d420f0301">[email&#160;protected]</a> (Sales enquiries)</span></div>
                        </div>
                    </div>
                    <div class="contact-info-card">
                        <div class="contact-icon">🌐</div>
                        <div>
                            <div class="contact-info-label">International Offices</div>
                            <div class="contact-info-value">Dubai · Singapore · Frankfurt · Chicago</div>
                        </div>
                    </div>

                    <div class="map-placeholder" style="margin-top:1.5rem;">
                        <div class="map-dot"></div>
                        <div>Karachi, Sindh, Pakistan</div>
                        <div style="font-size:0.75rem;color:rgba(138,154,176,0.5);">Pharma Industrial Estate, Malir District</div>
                    </div>
                </div>

                <form asp-controller="Website" asp-action="Contact" method="post">
                    <h3>Send Us a Message</h3>

                    <div class="form-group">
                        <label asp-for="Name">Full Name</label>
                        <input asp-for="Name" type="text" placeholder="Test Bhai" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Email">Email Address</label>
                        <input asp-for="Email" type="email" placeholder="test@gmail.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Phone">Phone</label>
                        <input asp-for="Phone" type="tel" placeholder="+92 555 0000000" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Subject">Subject</label>
                        <input asp-for="Subject" type="text" placeholder="Product enquiry — Capsule Filling" />
                        <span asp-validation-for="Subject" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Message">Message</label>
                        <textarea asp-for="Message" rows="5" placeholder="Tell us about your requirements..."></textarea>
                        <span asp-validation-for="Message" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary" style="width:100%;">
                        Send Message →
                    </button>

                
                </form>

            </div>
        

        </section>
       
    </div>

    


