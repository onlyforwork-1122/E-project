@{
    ViewData["Title"] = "Career";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="modal-overlay" id="email-modal">
    <div class="modal">
        <div class="modal-header">
            <div class="modal-title">Compose Email</div>
            <button class="modal-close" onclick="closeEmailModal()">✕</button>
        </div>
        <div id="email-send-success" class="alert alert-success hidden">✓ Email sent successfully!</div>
        <div class="form-group">
            <label>To</label>
            <input type="email" id="email-to" readonly style="opacity:0.7;" />
        </div>
        <div style="font-size:0.78rem;color:var(--text-muted);margin-top:-0.75rem;margin-bottom:1rem;" id="email-to-name"></div>
        <div class="form-group">
            <label>Subject</label>
            <input type="text" id="email-subject" placeholder="Interview Invitation — XYZ Pharmaceuticals" />
        </div>
        <div class="form-group">
            <label>Message</label>
            <textarea id="email-body" rows="8" placeholder="Dear [Name],&#10;&#10;We are pleased to invite you for an interview at XYZ Pharmaceuticals..."></textarea>
        </div>
        <div style="display:flex;gap:1rem;justify-content:flex-end;">
            <button class="btn btn-outline" onclick="closeEmailModal()">Cancel</button>
            <button class="btn btn-primary" onclick="sendEmail()">Send Email →</button>
        </div>
    </div>
</div>

<div class="page active" id="page-career">
    <div class="page-header">
        <div class="page-header-bg"></div>
        <div class="page-header-content">
            <div class="section-tag">Join Our Team</div>
            <h1>Careers at XYZ Pharma</h1>
            <p>Build the future of pharmaceutical manufacturing with us</p>
        </div>
    </div>

    <!-- Career Landing (not logged in) -->
    <div id="career-landing">
        <section class="section">
            <div class="grid-2" style="gap:3rem;align-items:start;">

                <!-- Login Panel -->
                <div class="card">
                    <div class="tabs">
                        <button class="tab-btn active" onclick="switchCareerTab('login')">Candidate Login</button>
                        <button class="tab-btn" onclick="switchCareerTab('register')">Create Account</button>
                    </div>

                    <!-- LOGIN -->
                    <div class="tab-content active" id="career-tab-login">
                        <form asp-controller="Website" asp-action="Login" method="post">
                        <h3 style="font-family:var(--font-display);font-size:1.5rem;margin-bottom:1.5rem;">Welcome Back</h3>
                        <div id="login-error" class="alert alert-error hidden">✗ Invalid email or password. Please try again.</div>
                        <div class="form-group"><label>Email Address</label><input type="email" name="email" id="login-email" placeholder="you@email.com" /></div>
                        <div class="form-group"><label>Password</label><input type="password" name="password" id="login-pass" placeholder="••••••••" /></div>
                        <button class="btn btn-primary" style="width:100%;margin-top:0.5rem;" type="submit">Login to My Account →</button>
                        <p style="text-align:center;color:var(--text-muted);font-size:0.82rem;margin-top:1rem;">Don't have an account? <a style="color:var(--teal);cursor:pointer;" onclick="switchCareerTab('register')">Create one here</a></p>
                        </form>
                    </div>

                    <!-- REGISTER -->
                    <div class="tab-content" id="career-tab-register">
                        <form asp-controller="Website" asp-action="Register" method="post">
                            <h3 style="font-family:var(--font-display);font-size:1.5rem;margin-bottom:1.5rem;">Create Your Profile</h3>
                            <div id="reg-error" class="alert alert-error hidden"></div>
                            <div class="form-row">
                                <div class="form-group"><label>First Name *</label><input type="text" name="FirstName" id="reg-fname" placeholder="First Name" /></div>
                                <div class="form-group"><label>Last Name *</label><input type="text" name="LastName" id="reg-lname" placeholder="Last Name" /></div>
                            </div>
                            <div class="form-group"><label>Email Address *</label><input type="email" name="Email" id="reg-email" placeholder="you@email.com" /></div>
                            <div class="form-row">
                                <div class="form-group"><label>Password *</label><input type="password" name="Password" id="reg-pass" placeholder="Min. 8 characters" /></div>
                                @* <div class="form-group"><label>Confirm Password *</label><input type="password" name="password" id="reg-pass2" placeholder="Re-enter password" /></div> *@
                            </div>
                            <div class="form-group"><label>Phone</label><input type="tel" name="Phone" id="reg-phone" placeholder="+91 98000 00000" /></div>

                            <button class="btn btn-primary" style="width:100%;margin-top:0.5rem;" type="submit">Create Account →</button>
                        </form>
                    </div>
                </div>

                <!-- Job Openings -->
                <div>
                    <h3 style="font-family:var(--font-display);font-size:1.5rem;margin-bottom:1.5rem;">Current Openings</h3>
                    <div style="display:flex;flex-direction:column;gap:1rem;">
                        <div class="card" style="padding:1.25rem;">
                            <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:0.5rem;">
                                <div>
                                    <div style="font-weight:700;color:var(--text-head);">Mechanical Design Engineer</div>
                                    <div style="font-size:0.8rem;color:var(--text-muted);margin-top:3px;">Mumbai · Full Time · 3–6 Years Exp</div>
                                </div>
                                <span class="badge badge-new">New</span>
                            </div>
                        </div>
                        <div class="card" style="padding:1.25rem;">
                            <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:0.5rem;">
                                <div>
                                    <div style="font-weight:700;color:var(--text-head);">Automation & PLC Engineer</div>
                                    <div style="font-size:0.8rem;color:var(--text-muted);margin-top:3px;">Pune · Full Time · 2–5 Years Exp</div>
                                </div>
                                <span class="badge badge-new">New</span>
                            </div>
                        </div>
                        <div class="card" style="padding:1.25rem;">
                            <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:0.5rem;">
                                <div>
                                    <div style="font-weight:700;color:var(--text-head);">International Sales Manager</div>
                                    <div style="font-size:0.8rem;color:var(--text-muted);margin-top:3px;">Mumbai · Full Time · 5–10 Years Exp</div>
                                </div>
                                <span class="badge badge-reviewed">Urgent</span>
                            </div>
                        </div>
                        <div class="card" style="padding:1.25rem;">
                            <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:0.5rem;">
                                <div>
                                    <div style="font-weight:700;color:var(--text-head);">Service & Field Engineer</div>
                                    <div style="font-size:0.8rem;color:var(--text-muted);margin-top:3px;">Multiple Locations · 1–3 Years Exp</div>
                                </div>
                                <span class="badge badge-new">New</span>
                            </div>
                        </div>
                    </div>
                </div>z
            </div>
        </section>
    </div>



</div>